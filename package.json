{
  "name": "firebase-leave-manager",
  "main": "expo-router/entry",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean --platform android",
    "prebuild:clean": "rm -rf android ios .expo && expo prebuild --clean",
    "build:android": "./scripts/build-android.sh",
    "build:android:apk": "cd android && ./gradlew assembleRelease",
    "build:android:aab": "cd android && ./gradlew bundleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:release": "./scripts/build-release.sh",
    "build:all": "./scripts/build-all.sh",
    "clean:android": "cd android && ./gradlew clean",
    "clean:all": "rm -rf android ios .expo node_modules/.cache",
    "android:keystore": "cd android/app && keytool -genkeypair -v -keystore release-key.jks -keyalg RSA -keysize 2048 -validity 10000 -alias trackmyleave",
    "build:eas:apk": "eas build --platform android --profile production-apk",
    "build:eas:aab": "eas build --platform android --profile production",
    "apply-campus-mapping:dry": "node ./scripts/apply_campus_mapping.js --csv ./scripts/sample_campus_map.csv",
    "apply-campus-mapping:update": "node ./scripts/apply_campus_mapping.js --csv ./scripts/sample_campus_map.csv --update"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-firebase/app": "^23.0.1",
    "@react-native-firebase/messaging": "^23.0.1",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-modules-core": "~3.0.29",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^11.10.0",
    "lucide-react-native": "^0.475.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli-server-api": "^18.0.0",
    "@types/react": "~19.1.10",
    "@types/react-native-push-notification": "^8.1.4",
    "cross-env": "^7.0.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
